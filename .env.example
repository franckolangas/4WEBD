JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
ADMIN_BOOTSTRAP_TOKEN=bootstrap-admin
INTERNAL_SYNC_TOKEN=internal-sync-token

# Reservation
RESERVATION_TTL_MIN=5
